#https://www.reddit.com/r/Ghostty/comments/1hw1jc2/my_ghostty_config/

# Appearance
theme = catppuccin-mocha
#background-opacity = 0.75
background-blur-radius = 40
font-size = 18
font-family = "MesloLGS Nerd Font Mono"
cursor-style = block
cursor-style-blink = false
background-blur-radius = 20
mouse-hide-while-typing = true


# macOS-specific settings
macos-titlebar-style = tabs
macos-option-as-alt = false 

keybind = super+alt+up=unbind
keybind = super+alt+down=unbind
keybind = super+alt+right=unbind
keybind = super+alt+left=unbind

# Extras
shell-integration = zsh
shell-integration-features = true
shell-integration-features = no-cursor
copy-on-select = clipboard
focus-follows-mouse = true
link-url = true

# Window controls
confirm-close-surface = true
#window-title-font-family = "MesloLGS Nerd Font Italic"
window-decoration = true
window-padding-x = 2
window-padding-y = 2
window-padding-balance = true
window-save-state = always

# Quick terminal (global keybinding) 
keybind = global:cmd+/=toggle_quick_terminal

# Reload Config
keybind = super+r=reload_config

# tmux-like prefix controlled keybindings
keybind = ctrl+a>x=close_surface
keybind = ctrl+a>t=new_tab 
keybind = ctrl+a>n=new_window
keybind = ctrl+a>f=toggle_fullscreen

# Tab navigation
keybind = ctrl+a>1=goto_tab:1
keybind = ctrl+a>2=goto_tab:2
keybind = ctrl+a>3=goto_tab:3
keybind = ctrl+a>4=goto_tab:4
keybind = ctrl+a>5=goto_tab:5
keybind = ctrl+a>6=goto_tab:6
keybind = ctrl+a>7=goto_tab:7
keybind = ctrl+a>8=goto_tab:8
keybind = ctrl+a>9=goto_tab:9

# Splits
keybind = ctrl+a+>|=new_split:right
keybind = ctrl+a+>alt+1=new_split:right
keybind = ctrl+a>-=new_split:down
keybind = ctrl+a>e=equalize_splits
keybind = ctrl+a>z=toggle_split_zoom

# Split navigation 
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>left=goto_split:left
keybind = ctrl+a>down=goto_split:bottom
keybind = ctrl+a>up=goto_split:top
keybind = ctrl+a>right=goto_split:right
